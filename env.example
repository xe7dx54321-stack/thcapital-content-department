# 同行资本内容系统本地路径配置示例
# 复制为 .env 或在 shell 中 export 后使用。

# 活跃市场内容系统目录。默认：仓库根目录/同行资本市场内容系统
# export THCAP_MARKET_CONTENT_ROOT="/path/to/thcapital-content-department/同行资本市场内容系统"

# 旧版内容生产系统目录。默认：仓库根目录/内容生产系统
# export THCAP_LEGACY_CONTENT_ROOT="/path/to/thcapital-content-department/内容生产系统"

# 内容工厂控制台目录。默认：仓库根目录/内容工厂控制台
# export THCAP_CONTENT_CONSOLE_ROOT="/path/to/thcapital-content-department/内容工厂控制台"

# 控制台监听地址和端口
# export CONTENT_FACTORY_DASHBOARD_HOST="127.0.0.1"
# export CONTENT_FACTORY_DASHBOARD_PORT="8780"

# 设为 1 时，doctor 会额外检查网络连通性。
# export THCAP_DOCTOR_NETWORK_CHECK=0
